# Copy to .env and adjust if your LM Studio runs elsewhere.
# All values have sane defaults baked into src/config.ts; .env is optional.

# LM Studio OpenAI-compatible endpoint
LM_BASE_URL=http://127.0.0.1:1234/v1
MODEL=qwen-agentworld-35b-a3b-oq4-mlx

# HTTP server
PORT=3000

# Bump this string to re-generate the entire simulated internet from scratch
# (old pages stay in the DB but are keyed under the previous epoch).
WORLD_EPOCH=v1

# Thinking mode. qwen-agentworld is a Language World Model whose chain-of-thought IS
# its simulation mechanism (arXiv:2606.24597). off = fast (we suppress thinking via an
# assistant-prefill); on = higher fidelity (the model reasons, we keep only the page).
# THINKING=on roughly doubles first-visit latency; cached revisits are unaffected.
THINKING=off

# Where the persistent world lives
DB_PATH=./world.db

# Bind address. Default 127.0.0.1 (loopback). Set HOST=0.0.0.0 to expose on
# your LAN — beware that /settings has no auth and can change the LLM
# endpoint + API key, so anyone reachable can exfiltrate your key.
HOST=127.0.0.1
